# Server Auth environment variables.
# ``http://127.0.0.1:8000/mcp`` is permitted by the loopback exception
# (RFC 8252 Section 7.3); production canonical URLs must be HTTPS.
MCP_RESOURCE_SERVER_CANONICAL_URL="http://127.0.0.1:8000/mcp"
MCP_RESOURCE_SERVER_AUTHORIZATION_SERVERS='[
  {
    "authorization_server_url": "https://your-workos.authkit.app",
    "issuer": "https://your-workos.authkit.app",
    "jwks_uri": "https://your-workos.authkit.app/oauth2/jwks",
    "algorithm": "RS256",
    "verify_options": {
      "verify_aud": false
    }
  }
]'

# RECOMMENDED baseline: PRM (RFC 9728) and the entry-401 challenge
# (RFC 6750) advertise the same minimum scope set. Tools that need
# elevated scopes raise InsufficientScopeError at dispatch time,
# producing a 403 step-up challenge.
MCP_RESOURCE_SERVER_SCOPES_SUPPORTED="mcp offline_access"
MCP_RESOURCE_SERVER_DEFAULT_CHALLENGE_SCOPES="mcp offline_access"

# Tool Secrets
MY_SECRET_KEY="Your tools can have secrets injected at runtime!"
