# SmartCritic live integration tests — copy this file to `.env` in the same
# directory and fill in your real keys. `.env` is already git-ignored.
#
#   cp .env.example .env
#   $EDITOR .env
#
# Then run the live tests:
#
#   uv run pytest libs/tests/arcade_evals/test_smart_critic_live.py \
#       -m smart_critic_live --no-cov -v

OPENAI_API_KEY=sk-...your-openai-key...
ANTHROPIC_API_KEY=sk-ant-...your-anthropic-key...

# Optional — override the default judge models used by the live tests.
# Defaults track the latest fast/cheap tiers (as of Apr 2026):
#   OpenAI:    gpt-5.4-mini          (gpt-5.4 family, mini tier)
#   Anthropic: claude-haiku-4-5-20251001
# Set these if you want to upgrade to a bigger judge (e.g. gpt-5.4,
# claude-sonnet-4-6, claude-opus-4-7).
# SMART_CRITIC_OPENAI_MODEL=gpt-5.4-mini
# SMART_CRITIC_ANTHROPIC_MODEL=claude-haiku-4-5-20251001
